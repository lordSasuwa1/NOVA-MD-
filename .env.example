# ─────────────────────────────────────────────
#         NOVA-MD — Variables d'environnement
#         Copie ce fichier en .env et remplis-le
# ─────────────────────────────────────────────

# ─── IDENTITÉ DU BOT ──────────────────────────
BOT_NAME=NOVA-MD
BOT_VERSION=1.0.0
OWNER_NAME=Sasuwa

# ─── NUMÉROS OWNER ────────────────────────────
# Ton numéro sans + ni espaces (ex: 22900000000)
OWNER_NUMBER=22900000000

# Numéros développeurs séparés par virgule
DEV_NUMBERS=

# ─── BOT ──────────────────────────────────────
PREFIX=!
# true = répond uniquement aux messages du bot lui-même
SELF_MODE=false
LANGUAGE=fr

# ─── SESSION BAILEYS ──────────────────────────
# Nom du dossier de session dans sessions/
SESSION_ID=main

# ─── API KEYS ─────────────────────────────────
CLAUDE_API_KEY=sk-ant-...
OPENAI_API_KEY=
WEATHER_API_KEY=
GIPHY_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── LIMITES ──────────────────────────────────
MAX_WARN=3
MAX_SPAM_MSG=5
SPAM_WINDOW=5000
MAX_FILE_SIZE=50
COOLDOWN=2000

# ─── NSFW ─────────────────────────────────────
# false = désactivé par défaut sur tous les groupes
NSFW_ENABLED=false

# ─── THÈME ────────────────────────────────────
# cybernetique | cerisier | anime
THEME=cybernetique

# ─── LOGS ─────────────────────────────────────
LOG_ACTIVITY=true
LOG_ERRORS=true
